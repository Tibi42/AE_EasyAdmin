server {
    listen 80;
    server_name ton-domaine.com www.ton-domaine.com;
    # Redirige tout le HTTP vers HTTPS (à activer après certbot)
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name ton-domaine.com www.ton-domaine.com;
    root /var/www/ae_easyadmin/public;

    # SSL — géré automatiquement par certbot
    ssl_certificate     /etc/letsencrypt/live/ton-domaine.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/ton-domaine.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # --- Webhook GitHub ---
    # Bloc dédié AVANT le bloc "/" pour avoir la priorité
    location = /webhook.php {
        fastcgi_pass unix:/var/run/php/php8.4-fpm.sock;
        fastcgi_split_path_info ^(.+\.php)(/.*)$;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT   $realpath_root;

        # Timeout long car deploy.sh peut prendre du temps
        fastcgi_read_timeout 120;
    }

    # --- App Symfony ---
    location / {
        try_files $uri /index.php$is_args$args;
    }

    location ~ ^/index\.php(/|$) {
        fastcgi_pass unix:/var/run/php/php8.4-fpm.sock;
        fastcgi_split_path_info ^(.+\.php)(/.*)$;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT   $realpath_root;
        internal;
    }

    # Bloque tous les autres fichiers PHP
    location ~ \.php$ {
        return 404;
    }

    error_log  /var/log/nginx/ae_easyadmin_error.log;
    access_log /var/log/nginx/ae_easyadmin_access.log;
}
